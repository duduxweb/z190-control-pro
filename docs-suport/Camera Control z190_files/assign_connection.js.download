// JavaScript Document
var g_isAssignProxyRecVisable = true;
AssignCtrl = {
	
	GetValue : function()
	{
		var names = {"Button.Assign":["*"]};
		var id = client.property.GetValue({params: names, onresponse: function(resp) {
			var respAssign = JSON.stringify(resp.error || resp.result);
			var AssignData = JSON.parse(respAssign);
			if (AssignData == "timeout")
			{
			}
			else
			{
				j.each(AssignData, function(key, value) 
				{
					if ("Button.Assign" == key) 
					{				
						SetAssignBtnProperties(value);
					}
				});
			}
		}, timeout : 3000});
	},
	
	GetCapability : function()
	{
		var names = ["Button.Assign"];
		var id = client.capability.GetValue({params: names, onresponse: function(resp) {
			var respStr = JSON.stringify(resp.error || resp.result);
			var strData = JSON.parse(respStr);
			if (strData == "timeout")
			{
			}
			else
			{
				j.each(strData, function(key, value) 
				{
					if ("Button.Assign" == key) 
					{
						var tmpClickAssignBtnIndex = 0;
						switch(g_clickAssignBtnIndex)
						{
							case 1:
							case 2:
								tmpClickAssignBtnIndex = g_clickAssignBtnIndex - 1;
								break;
							default:
								tmpClickAssignBtnIndex = g_clickAssignBtnIndex - 1;
								break;
						}
						SetAssignBtnList(value , tmpClickAssignBtnIndex);
					}
				});
				
				
				if (parseInt(g_arrAssignLableList[g_clickAssignBtnIndex - 1].id) == 5)
				{
					if (g_objAssignLable_5.innerHTML == "Zoom W/T"
						|| g_objAssignLable_5.innerHTML == "Zoom T/W")
					{
					}
					else
					{
						
						SetAssignListSelsctForSpecialItems(g_arrAssignLableList[g_clickAssignBtnIndex - 1].innerHTML, g_clickAssignBtnIndex - 1);
//						if (g_arrAssignLableList[g_clickAssignBtnIndex - 1].innerHTML == "Cont Rec")
//						{
//							g_arrAssignLableList[g_clickAssignBtnIndex - 1].userData[1].SetSelect("Clip Continuous Rec");
//						}
//						else if (g_arrAssignLableList[g_clickAssignBtnIndex - 1].innerHTML == "Cache Rec")
//						{
//							g_arrAssignLableList[g_clickAssignBtnIndex - 1].userData[1].SetSelect("Picture Cache Rec");
//						}
//						else
//						{
//							g_arrAssignLableList[g_clickAssignBtnIndex - 1].userData[1].SetSelect(g_arrAssignLableList[g_clickAssignBtnIndex - 1].innerHTML);
//						}
					}
				}
				else
				{
					SetAssignListSelsctForSpecialItems(g_arrAssignLableList[g_clickAssignBtnIndex - 1].innerHTML, g_clickAssignBtnIndex - 1);
//					g_arrAssignLableList[g_clickAssignBtnIndex - 1].userData[1].SetSelect(g_arrAssignLableList[g_clickAssignBtnIndex - 1].innerHTML);
//					if (g_arrAssignLableList[g_clickAssignBtnIndex - 1].innerHTML == "Cont Rec")
//					{
//						g_arrAssignLableList[g_clickAssignBtnIndex - 1].userData[1].SetSelect("Clip Continuous Rec");
//					}
