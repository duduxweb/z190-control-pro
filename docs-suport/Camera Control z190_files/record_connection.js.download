	{
        var params = ["main"];
        var id = client.clip.recorder.Stop({params: params, onresponse: function(resp){
                                               
        }});
	},
		
	RecorderStartRecord : function()
	{

        var params = ["main"];
        var id = client.clip.recorder.Start({params: params, onresponse: function(resp){
                                               
        }});
	},	
