	NotifySubscribe : function () {
		names = [];
		names.push("Notify.Property");
		names.push("Notify.Properties");
		names.push("Notify.Process");
		var id = client.notify.Subscribe({params: names,	onresponse: function(resp){
									
		}});
	},
	
	NotifyUnsubscribe : function () {
		names = [];
		names.push("Notify.Properties");
		var id = client.notify.Unsubscribe({params: names,	onresponse: function(resp){
										
		}});
	},

	NotifyRecordStatusByCardStatus :function (){
        if(IsMediaAactive&&IsMediaAMount)
        {
            MediaStatus = 0;
            //j("#"+MediaCardEle[MediaStatus]).css({"background-image":MediaCardPng[MediaStatus]});
            //j("#"+MediaCardEle[1]).css({"background-image":"url(../../WebCommon/images/Parts_PFXR_T_CC_Status_MediaCard_NoMedia.png)"});
            j("#"+AppStatText[1]).text("");
            if ("Standby" == CameraStatus)
            {
                g_MediaStatus = CameraStatus;
                j("#"+STBYORREC[0]).css({"background-image":""});
                j("#"+STBYORREC[1]).css({"background-image":""});
                if (g_IsSimulRecord)
                {
                    RecordCtrl.SetMediaStandbySpecialStatus();
                }
                else
                {
                    RecordCtrl.SetMediaStandbyStatus();
                }
            }else if ("Recording" == CameraStatus)
            {
                g_MediaStatus = CameraStatus;
                if (g_IsSimulRecord)
                {
                    RecordCtrl.SetMediaRecordingSpecialStatus();
                }
                else
                {
                    RecordCtrl.SetMediaRecordingStatus();
                }
            }
        }else if(IsMediaBactive&&IsMediaBMount)
        {
            MediaStatus=1;
            // j("#"+MediaCardEle[MediaStatus]).css({"background-image":MediaCardPng[MediaStatus]});
            //j("#"+MediaCardEle[0]).css({"background-image":""});
            // j("#"+MediaCardEle[0]).css({"background-image":"url(../../WebCommon/images/Parts_PFXR_T_CC_Status_MediaCard_NoMedia.png)"});
            j("#"+AppStatText[0]).text("");
            if ("Standby" == CameraStatus)
            {
                g_MediaStatus = CameraStatus;
                j("#"+STBYORREC[0]).css({"background-image":"none"});
                if (g_IsSimulRecord)
                {
                    RecordCtrl.SetMediaStandbySpecialStatus();
                }
                else
                {
                    RecordCtrl.SetMediaStandbyStatus();
                }
            }else if ("Recording" == CameraStatus)
            {
                g_MediaStatus = CameraStatus;
                if (g_IsSimulRecord)
                {
                    RecordCtrl.SetMediaRecordingSpecialStatus();
                }
                else
                {
                    RecordCtrl.SetMediaRecordingStatus();
                }
            }
        }else{
            MediaStatus = 2;
            // j("#"+MediaCardEle[0]).css({"background-image":"url(../../WebCommon/images/Parts_PFXR_T_CC_Status_MediaCard_NoMedia.png)"});
            // j("#"+MediaCardEle[1]).css({"background-image":"url(../../WebCommon/images/Parts_PFXR_T_CC_Status_MediaCard_NoMedia.png)"});
            j("#"+AppStatText[0]).text("");
            j("#"+AppStatText[1]).text("");
        }
	},





	NotifySetRecorderData : function (objArrItem)
	{
		var TimeCodeFlag = 1;
		for(var key in objArrItem)
		{
			if (key == "P.Clip.Mediabox.Status")
			{

                CameraStatus= objArrItem[key];

			}
			else if (key == "P.Clip.Mediabox.Mode")
			{
				if ("Normal" == objArrItem[key])
				{
					StatusMode = 0;
				}
				else if ("Interval" == objArrItem[key])
				{
					StatusMode = 2;
				}
				else if ("ClipContinuous" == objArrItem[key])
				{
					StatusMode = 3;
				}
				else if ("PictureCache" == objArrItem[key])
				{
					StatusMode = 4;
				}
				else if ("Frame" == objArrItem[key])
				{
					StatusMode = 5;
				}
				else
				{
					StatusMode = 1;
				}

			}
			else if (key == "P.Clip.Mediabox.Speed")
			{
				SpeedValue = Math.round(objArrItem[key]);
			}

			else if (key == "P.Clip.Mediabox.TimeCode.Type")
			{
				if (objArrItem[key] == "Unknown")
				 {
				 	j("#0_TCG_NAME").text("");
				 	TimeCodeFlag = 0;
				 }
				 else if (objArrItem[key] == "Duration")
				 {
				 	j("#0_TCG_NAME").text("Dur");
				 	TimeCodeFlag = 1;
				 }
				 else if (objArrItem[key] == "Counter")
				 {
					j("#0_TCG_NAME").text("Cnt");
				 	TimeCodeFlag = 1;
				 }
				 /*else if (value == "TimeCode")
				 {
				 	j("#0_TCG_NAME").text("TC");
				 	TimeCodeFlag = 1;
				 }
				 else if (value == "UB")
				 {
				 	j("#0_TCG_NAME").text("UB");
				 	TimeCodeFlag = 1;
				 }*/
				 else
				 {
				 	j("#0_TCG_NAME").text(objArrItem[key]);
				 	TimeCodeFlag = 1;
				 }
			}
			else if (key == "P.Clip.Mediabox.TimeCode.Value")
			{
				if (TimeCodeFlag == 0)
				{
					j("#1_TIMECODE_VALUE").text("");
				}
				else
				{
					j("#1_TIMECODE_VALUE").text(objArrItem[key]);
					if ($("0_TCG_NAME").innerHTML == "UBG")
					{
						$("1_TIMECODE_VALUE").style.fontSize = "30px";
					}
					else
					{
						$("1_TIMECODE_VALUE").style.fontSize = "36px";
					}
				}
			}
			else if (key == "P.Clip.Mediabox.TimeCode.Locked")//return bool
			{
				if (true == objArrItem[key])
				{
					j("#0_EXT_LK_NAME").text("Ext-Lk");
				}
				else if (false == objArrItem[key])
				{
					j("#0_EXT_LK_NAME").text("");
				}
				else if ("true" == objArrItem[key])
				{
					j("#0_EXT_LK_NAME").text("Ext-Lk");
				}
				else
				{
					j("#0_EXT_LK_NAME").text("");
				}
			}
			else if (key == "P.Clip.Mediabox.SimulRec.Enabled")
			{
				g_IsSimulRecord = objArrItem[key];
				if (g_IsSimulRecord)
				{
					if (g_MediaStatus == "Standby" || "RecPausing" == g_MediaStatus)
					{
						RecordCtrl.SetMediaStandbySpecialStatus();
					}
					else if (g_MediaStatus == "Recording")
					{
						RecordCtrl.SetMediaRecordingSpecialStatus();
					}
				}
				else
				{
					if (g_MediaStatus == "Standby" || "RecPausing" == g_MediaStatus)
					{
						RecordCtrl.SetMediaStandbyStatus();
					}
					else if (g_MediaStatus == "Recording")
					{
						RecordCtrl.SetMediaRecordingStatus();
					}
				}
			}
            else if(key == "P.Clip.Mediabox.SimulRec.Mode")
            {
                g_SimulateMode = objArrItem[key];
            }
			else
			{
			}
            RecordCtrl.UpdateRecordStatus(key);
			SetCardNotifyData({});
			SetAudioNotifyData({});
             }
	},

    UpdateRecordStatus :function (key)
    {
    if(key == "P.Clip.Mediabox.Status"|| key == "P.Clip.Mediabox.Mode"|| key == "P.Clip.Mediabox.Speed" || key == "Storage.Drive.Status" || key == "System.Storage")
    {
        if ("Recording" == CameraStatus || "RecordingWithCall" == CameraStatus || "RecPausing" == CameraStatus)
        {
            if (RECRedStatusValue != 1)
            {
                j("#"+STBYORREC[0]).css({"background-image":"url(../../WebCommon/images/Parts_PFXR_T_CC_Status_Rec.png)"});
                RECRedStatusValue = 1;
            }
        }
        else//"Ready"
        {
            if (RECRedStatusValue != 0)
            {
                j("#"+STBYORREC[MediaStatus]).css({"background-image":""});
                RECRedStatusValue = 0;
            }
        }

        if ("Playing" == CameraStatus)
        {
            PlayBackInfoStatusValue = 1;
        }
        else if ("Standby" == CameraStatus || "NoMedia" == CameraStatus)
        {
            j("#"+STBYORREC[0]).css({"background-image":"none"});
            if (PlayBackInfoStatusValue != 0)
            {
                PlayBackInfoStatusValue = 0;
            }
        }
        else if ("Recording" == CameraStatus)
        {
            PlayBackInfoStatusValue = 0;
        }


        if ("NoMedia" == CameraStatus)
        {
            g_MediaStatus = CameraStatus;
            j("#DIV_STATUS").text("");
            j("#2_DIV_STATUS").text("");
            j("#3_DIV_STATUS").text("");
            j("#2_DIV_STATUS").css({"background-image":"none"});
            Status1Value = "";
            Status2Value = "";
            if (g_IsSimulRecord)
            {
                j("#3_DIV_STATUS").text("Simul");
            }
            else
            {
                RecordCtrl.SetNoMediaStatus();
            }

        }
        else if ("Recording" == CameraStatus)
        {
            g_MediaStatus = CameraStatus;
            if (g_IsSimulRecord)
            {
                RecordCtrl.SetMediaRecordingSpecialStatus();
            }
            else
            {
                RecordCtrl.SetMediaRecordingStatus();
            }
        }
        else if ("Standby" == CameraStatus)
        {
            g_MediaStatus = CameraStatus;
            if (g_IsSimulRecord)
            {
                RecordCtrl.SetMediaStandbySpecialStatus();
            }
            else
            {
                RecordCtrl.SetMediaStandbyStatus();
            }
        }
        else if ("RecPausing" == CameraStatus)
        {
            g_MediaStatus = CameraStatus;
            if (g_IsSimulRecord)
            {
                RecordCtrl.SetMediaStandbySpecialStatus();
            }
            else
            {
                RecordCtrl.SetMediaStandbyStatus();
            }
        }
        else if ("Playing" == CameraStatus)
        {
            g_MediaStatus = CameraStatus;
            j("#2_DIV_STATUS").css({"background-image":"none"});
            if (SpeedValue == 1)
            {
                j("#"+STBYORREC[0]).css({"background-image":"url(../../WebCommon/images/Parts_PFXR_T_CC_Status_Play.png)"});
                j("#"+AppStatText[0]).text("Play");
                j("#"+AppStatText[0]).css({color:"#fff"});
                // j("#2_DIV_STATUS").text("");
                j("#3_DIV_STATUS").text("");
                Status1Value = "Play";
                Status2Value = "";
            }
            else if (SpeedValue == 0)
            {
                j("#"+STBYORREC[0]).css({"background-image":"url(../../WebCommon/images/Parts_PFXR_T_CC_Status_Pause.png)"});
                j("#"+AppStatText[0]).text("Pause");
                j("#"+AppStatText[0]).css({color:"#fff"});
                // j("#2_DIV_STATUS").text("");
                j("#3_DIV_STATUS").text("");
                Status1Value = "Pause";
                Status2Value = "";
            }
            else if (SpeedValue  > 1)
            {
                j("#"+STBYORREC[0]).css({"background-image":"url(../../WebCommon/images/Parts_PFXR_T_CC_Status_FFwd.png)"});
                j("#"+AppStatText[0]).text("Fwdx" + SpeedValue);
                j("#"+AppStatText[0]).css({color:"#fff"});
                // j("#2_DIV_STATUS").text("");
                j("#3_DIV_STATUS").text("");
                Status1Value = "Fwdx" + SpeedValue;
                Status2Value = "";
            }
            else if (SpeedValue  < 0)
            {
                j("#"+STBYORREC[0]).css({"background-image":"url(../../WebCommon/images/Parts_PFXR_T_CC_Status_FRev.png)"});
                var SpeedValueAbs = -SpeedValue;
                j("#"+AppStatText[0]).text("Revx" + SpeedValueAbs);
                j("#"+AppStatText[0]).css({color:"#fff"});
                // j("#2_DIV_STATUS").text("");
                j("#3_DIV_STATUS").text("");
                Status1Value = "Revx" + SpeedValueAbs;
                Status2Value = "";
            }
            else
            {
                j("#"+STBYORREC[0]).css({"background-image":"url(../../WebCommon/images/Parts_PFXR_T_CC_Status_Play.png)"});
                j("#"+AppStatText[0]).text("Play");
                j("#"+AppStatText[0]).css({color:"#fff"});
                // j("#2_DIV_STATUS").text("");
                j("#3_DIV_STATUS").text("");
                Status1Value = "Play";
                Status2Value = "";
            }


        }
        else if ("Pausing" == CameraStatus)
        {
            g_MediaStatus = CameraStatus;
            j("#"+AppStatText[0]).text("Pause");
            j("#"+AppStatText[0]).css({color:"#fff"});
            // j("#2_DIV_STATUS").text("");
            j("#3_DIV_STATUS").text("");
            Status1Value = "Pause";
            Status2Value = "";
        }
        else if ("Stopping" == CameraStatus)
        {
            g_MediaStatus = CameraStatus;
            j("#"+AppStatText[0]).text("Stop");
            j("#"+AppStatText[0]).css({color:"#fff"});
            // j("#2_DIV_STATUS").text("");
            j("#3_DIV_STATUS").text("");
            Status1Value = "Stop";
            Status2Value = "";
        }
        else
        {
            g_MediaStatus = "";
            j("#DIV_STATUS").text("");
            j("#2_DIV_STATUS").text("");
            j("#3_DIV_STATUS").text("");
            Status1Value = "";
            Status2Value = "";
        }
    }
}
}




