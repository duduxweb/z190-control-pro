function SetAssignBtnList (assignValueItems, assignIndex)
{
	j.each(assignValueItems, function(key, value){
		var assignBtnIndex = key.substr(11, 1);
		if ((assignBtnIndex >= 0) && (assignBtnIndex <= 10))
		{	
			if (assignIndex != assignBtnIndex)
			{
				return;
			}
			var listItem = new Array();
			for (var i = 0; i < value[2].length; i++)
			{
				for (var m = 0; m < g_arrGetAssignKeyMap.length; m++)
				{
					if (value[2][i] == g_arrGetAssignKeyMap[m] && 
							(g_arrGetAssignKeyMap[m] != "ProxyRecStartStop"
							|| (g_arrGetAssignKeyMap[m] == "ProxyRecStartStop" && g_isAssignProxyRecVisable)))
					{
						listItem.push(g_arrGetAssignItemMap[g_arrGetAssignKeyMap[m]]);
						break;
					}
				}
			}
			
			g_arrAssignLableList[assignBtnIndex].userData[1].ChangeDlgItems(listItem);
		}
	})
}

function SetAssignLabelTextForSpecialItems(value, index)
{
	switch (value)
	{
		case "Clip Continuous Rec":
			g_arrAssignLableList[index].innerHTML = "Cont Rec";
			break;
		case "Focus Magnifier":
			g_arrAssignLableList[index].innerHTML = "Focus Mag";
			break;
		case "Picture Cache Rec":
			g_arrAssignLableList[index].innerHTML = "Cache Rec";
			break;
		case "Network Client Mode":
			g_arrAssignLableList[index].innerHTML = "NW Client";
			break;
		case "Auto Upload(Proxy)":
			g_arrAssignLableList[index].innerHTML = "Auto Up";
			break;
		case "XAVC Proxy Rec Start":
			g_arrAssignLableList[index].innerHTML = "Proxy Rec";
			break;
		case "Video Signal Monitor":
			g_arrAssignLableList[index].innerHTML = "Signal Monitor";
			break;
		default:
			g_arrAssignLableList[index].innerHTML = value;
			break;
	}
}

function SetAssignListSelsctForSpecialItems(value, index)
{
	switch (value)
	{
		case "Cont Rec":
			g_arrAssignLableList[index].userData[1].SetSelect("Clip Continuous Rec");
			break;
		case "Focus Mag":
			g_arrAssignLableList[index].userData[1].SetSelect("Focus Magnifier");
			break;
		case "Cache Rec":
			g_arrAssignLableList[index].userData[1].SetSelect("Picture Cache Rec");
			break;
		case "NW Client":
			g_arrAssignLableList[index].userData[1].SetSelect("Network Client Mode");
			break;
		case "Auto Up":
			g_arrAssignLableList[index].userData[1].SetSelect("Auto Upload(Proxy)");
			break;
		case "Proxy Rec":
			g_arrAssignLableList[index].userData[1].SetSelect("XAVC Proxy Rec Start");
			break;
		case "Signal Monitor":
			g_arrAssignLableList[index].userData[1].SetSelect("Video Signal Monitor");
			break;
		default:
			g_arrAssignLableList[index].userData[1].SetSelect(value);
			break;
	}
}

